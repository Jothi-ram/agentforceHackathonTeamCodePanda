<?xml version="1.0" encoding="UTF-8"?>
<AppointmentSchedulingPolicy xmlns="http://soap.sforce.com/2006/04/metadata">
    <appointmentStartTimeInterval>30</appointmentStartTimeInterval>
    <isSvcTerrOpHoursWithShiftsUsed>false</isSvcTerrOpHoursWithShiftsUsed>
    <isSvcTerritoryMemberShiftUsed>false</isSvcTerritoryMemberShiftUsed>
    <masterLabel>Test Drive Scheduling Policy</masterLabel>
    <shouldCheckExternalCalendar>false</shouldCheckExternalCalendar>
    <shouldConsiderCalendarEvents>true</shouldConsiderCalendarEvents>
    <shouldEnforceExcludedResource>false</shouldEnforceExcludedResource>
    <shouldEnforceRequiredResource>false</shouldEnforceRequiredResource>
    <shouldMatchSkill>true</shouldMatchSkill>
    <shouldMatchSkillLevel>false</shouldMatchSkillLevel>
    <shouldRespectVisitingHours>false</shouldRespectVisitingHours>
    <shouldUsePrimaryMembers>true</shouldUsePrimaryMembers>
    <shouldUseSecondaryMembers>false</shouldUseSecondaryMembers>
</AppointmentSchedulingPolicy>
