// Code Generated by Sidekick is for learning and experimentation purposes only.

public class BookTestDriveAction {
    
    @InvocableMethod(label='Book Test Drive Appointment' 
                     description='Books test drive and assigns dealer to lead')
    public static List<BookingResult> bookTestDrive(List<BookingRequest> requests) {
        List<BookingResult> results = new List<BookingResult>();
        
        for (BookingRequest request : requests) {
            BookingResult result = new BookingResult();
            
            try {
                // STEP 1: Call your existing "Get Best Dealer" flow
                Map<String, Object> flowInputs = new Map<String, Object>{
                    'varCustomerName' => request.customerName,
                    'varZipCode' => request.zipCode,
                    'varPreferredDateTime' => request.preferredDateTime,
                    'varModel' => request.vehicleModel,
                    'varInputMobile' => request.customerMobile,
                    'varInputEmail'  => request.customerEmail
                };
                
                Flow.Interview.Get_Best_Dealer flowInstance = 
                    new Flow.Interview.Get_Best_Dealer(flowInputs);
                flowInstance.start();
                
                // STEP 2: Get dealer from flow output
                Account bestDealer = (Account)flowInstance.getVariableValue('varBestOfDealer');
                
                
                // STEP 3: Handle case where no dealer available (race condition)
                if (bestDealer == null || bestDealer.Id == null) {
                    result.success = false;
                    result.suggestAlternative = true;
                    result.errorMessage = 'Sorry, that time slot just got taken by another customer! ' +
                                        'Let me show you other available times.';
                    results.add(result);
                    continue;
                }
                
                // STEP 4: Get full dealer details
                Account dealer = [
                    SELECT Id, Name, Phone, 
                           BillingStreet, BillingCity, BillingState, BillingPostalCode
                    FROM Account
                    WHERE Id = :bestDealer.Id
                    LIMIT 1
                ];
                
                // STEP 5: Update Lead with dealer assignment
                if (String.isNotBlank(request.leadId)) {
                    Lead l = new Lead(
                        Id = request.leadId,
                        Assigned_Delear__c = dealer.Id,
                        Status = 'Test Drive Appointment Scheduled'
                    );
                    update l;
                }
                
                // STEP 6: Build success result
                result.success = true;
                result.suggestAlternative = false;
                result.dealerName = dealer.Name;
                result.dealerPhone = dealer.Phone;
                result.dealerAddress = formatAddress(dealer);
                result.confirmationMessage = buildConfirmation(request, dealer);
                
            } catch (Exception e) {
                result.success = false;
                result.suggestAlternative = false;
                result.errorMessage = 'Sorry, there was an issue completing your booking. ' +
                                    'Please call us at 1-800-ELECTRA for assistance.';
                System.debug('BookTestDrive Error: ' + e.getMessage() + ' | ' + e.getStackTraceString());
            }
            
            results.add(result);
        }
        
        return results;
    }
    
    // Helper: Format address
    private static String formatAddress(Account dealer) {
        List<String> parts = new List<String>();
        if (String.isNotBlank(dealer.BillingStreet)) parts.add(dealer.BillingStreet);
        if (String.isNotBlank(dealer.BillingCity)) parts.add(dealer.BillingCity);
        if (String.isNotBlank(dealer.BillingState)) parts.add(dealer.BillingState);
        if (String.isNotBlank(dealer.BillingPostalCode)) parts.add(dealer.BillingPostalCode);
        return String.join(parts, ', ');
    }
    
    // Helper: Build confirmation message
    private static String buildConfirmation(BookingRequest request, Account dealer) {
        String dateTimeFormatted = request.preferredDateTime.format('EEEE, MMMM d \'at\' h:mm a');
        
        return '✅ Perfect! Your test drive is confirmed:\n\n' +
               '📅 ' + dateTimeFormatted + '\n' +
               '🚗 Vehicle: ' + request.vehicleModel + '\n' +
               '📍 Location: ' + dealer.Name + '\n' +
               '     ' + dealer.BillingStreet + '\n' +
               '     ' + dealer.BillingCity + ', ' + dealer.BillingState + ' ' + dealer.BillingPostalCode + '\n' +
               '📞 Phone: ' + dealer.Phone + '\n\n' +
               '⚠️ Please bring a valid driver\'s license.\n' +
               'We\'ll send you a confirmation email shortly.\n\n' +
               'See you soon!';
    }
    
    // Input/Output classes
    public class BookingRequest {
        @InvocableVariable(required=true label='Lead ID')
        public String leadId;
        
        @InvocableVariable(required=true label='Customer Name')
        public String customerName;
        
        @InvocableVariable(required=true label='Zip Code')
        public String zipCode;
        
        @InvocableVariable(required=true label='Vehicle Model')
        public String vehicleModel;
        
        @InvocableVariable(required=true label='Customer Mobile')
        public String customerMobile;
        
        @InvocableVariable(required=true label='Customer Email')
        public String customerEmail;
        
        @InvocableVariable(required=true label='Preferred Date/Time')
        public DateTime preferredDateTime;
    }
    
    public class BookingResult {
        @InvocableVariable(label='Success')
        public Boolean success;
        
        @InvocableVariable(label='Suggest Alternative Time')
        public Boolean suggestAlternative;
        
        @InvocableVariable(label='Dealer Name')
        public String dealerName;
        
        @InvocableVariable(label='Dealer Phone')
        public String dealerPhone;
        
        @InvocableVariable(label='Dealer Address')
        public String dealerAddress;
        
        @InvocableVariable(label='Confirmation Message')
        public String confirmationMessage;
        
        @InvocableVariable(label='Error Message')
        public String errorMessage;
    }
}